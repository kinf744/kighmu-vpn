<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark">

    <!-- Toolbar Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:background="@color/surface_dark">

        <!-- Filter chips -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_all"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="ALL"
            android:textSize="11sp"
            app:chipBackgroundColor="@color/accent_blue"
            android:textColor="@color/text_primary"
            android:layout_marginEnd="4dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_info"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="INFO"
            android:textSize="11sp"
            app:chipBackgroundColor="@color/surface_dark_elevated"
            android:textColor="@color/text_secondary"
            android:layout_marginEnd="4dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_error"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="ERROR"
            android:textSize="11sp"
            app:chipBackgroundColor="@color/surface_dark_elevated"
            android:textColor="@color/error_red"
            android:layout_marginEnd="4dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_warning"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="WARN"
            android:textSize="11sp"
            app:chipBackgroundColor="@color/surface_dark_elevated"
            android:textColor="@color/warning_orange"
            android:layout_marginEnd="0dp" />

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_share_logs"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Share"
            android:textSize="12sp"
            android:textColor="@color/accent_blue" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clear_logs"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Clear"
            android:textSize="12sp"
            android:textColor="@color/error_red" />

    </LinearLayout>

    <!-- Auto scroll toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:gravity="center_vertical"
        android:background="@color/surface_dark">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Auto-scroll"
            android:textSize="13sp"
            android:textColor="@color/text_secondary" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_auto_scroll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            app:thumbTint="@color/accent_blue"
            app:trackTint="@color/surface_dark_elevated" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/surface_dark_elevated" />

    <!-- Log List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_logs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/background_dark"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        android:scrollbars="vertical" />

</LinearLayout>
