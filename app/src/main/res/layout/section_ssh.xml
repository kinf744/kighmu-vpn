<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/surface_card"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SSH CREDENTIALS"
                android:textSize="11sp"
                android:textColor="@color/accent_blue"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="These credentials apply to all SSH-based modes"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:layout_marginBottom="16dp" />

            <!-- SSH Host -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:boxStrokeColor="@color/accent_blue"
                app:hintTextColor="@color/text_hint"
                android:hint="@string/ssh_host">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_ssh_host"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:inputType="textUri" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- SSH Port -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:boxStrokeColor="@color/accent_blue"
                app:hintTextColor="@color/text_hint"
                android:hint="@string/ssh_port">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_ssh_port"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:inputType="number"
                    android:text="22" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Username -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:boxStrokeColor="@color/accent_blue"
                app:hintTextColor="@color/text_hint"
                android:hint="@string/ssh_username">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_ssh_user"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:inputType="textNoSuggestions" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:boxStrokeColor="@color/accent_blue"
                app:hintTextColor="@color/text_hint"
                app:endIconMode="password_toggle"
                android:hint="@string/ssh_password">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_ssh_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Use Key Switch -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/ssh_use_key"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_use_key"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="@color/accent_blue"
                    app:trackTint="@color/surface_dark_elevated" />
            </LinearLayout>

            <!-- Private Key -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:boxStrokeColor="@color/accent_blue"
                app:hintTextColor="@color/text_hint"
                android:hint="@string/ssh_private_key">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_private_key"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:minLines="4"
                    android:maxLines="10"
                    android:gravity="top"
                    android:inputType="textMultiLine|textNoSuggestions" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
