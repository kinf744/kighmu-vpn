<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#F5F5F5">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="0dp">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="56dp"
            android:background="#009688" android:orientation="horizontal"
            android:gravity="center_vertical" android:padding="16dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Exporteur de configuration"
                android:textColor="#FFFFFF" android:textSize="18sp"/>
            </LinearLayout>

        <!-- Nom fichier -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="#FFFFFF" android:orientation="vertical"
            android:padding="16dp" android:layout_marginTop="8dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Nom du fichier" android:textColor="#888888" android:textSize="12sp"/>
            <EditText android:id="@+id/et_export_filename"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="kighmu_config" android:textColor="#000000"
                android:textColorHint="#AAAAAA" android:background="@null"
                android:padding="8dp"/>
        </LinearLayout>

        

        <!-- Options Extra -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="  Extra" android:textColor="#009688" android:textSize="13sp"
            android:background="#E0F2F1" android:padding="12dp" android:layout_marginTop="8dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="#FFFFFF" android:orientation="vertical" android:padding="8dp">

            <CheckBox android:id="@+id/cb_mobile_data_only"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="Réseau de données mobiles uniquement"
                android:textColor="#333333" android:paddingStart="8dp"/>
            <CheckBox android:id="@+id/cb_lock_operator"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="Verrouiller l'opérateur mobile"
                android:textColor="#333333" android:paddingStart="8dp"/>
            <CheckBox android:id="@+id/cb_attest_device"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="Attester l'appareil 🛡️"
                android:textColor="#333333" android:paddingStart="8dp"/>
            <CheckBox android:id="@+id/cb_block_root"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="Bloquer l'appareil rooté"
                android:textColor="#333333" android:paddingStart="8dp"/>
            <CheckBox android:id="@+id/cb_playstore_only"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="Installation Play Store uniquement"
                android:textColor="#333333" android:paddingStart="8dp"/>
            <CheckBox android:id="@+id/cb_lock_device_id"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="Verrouillage de l'ID de l'appareil"
                android:textColor="#333333" android:paddingStart="8dp"/>
            <CheckBox android:id="@+id/cb_set_expiry"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="Définir la date d'expiration"
                android:textColor="#333333" android:paddingStart="8dp"/>
            <LinearLayout android:id="@+id/layout_expiry"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingBottom="8dp" android:visibility="gone">
                <TextView android:id="@+id/tv_expiry_date"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Aucune date sélectionnée"
                    android:textColor="#888888" android:textSize="13sp"/>
                <Button android:id="@+id/btn_pick_date"
                    android:layout_width="wrap_content" android:layout_height="36dp"
                    android:text="📅 Choisir" android:backgroundTint="#009688"
                    android:textColor="#FFFFFF" android:textSize="11sp"/>
            </LinearLayout>
            <CheckBox android:id="@+id/cb_disable_override"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="Désactiver l'écrasement utilisateur du type de tunnel et du serveur"
                android:textColor="#333333" android:paddingStart="8dp"/>
            <CheckBox android:id="@+id/cb_lock_all_config"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="🔒 Verrouiller toute la configuration (lecture seule)"
            android:textColor="#E53935" android:paddingStart="8dp"
            android:textStyle="bold"/>
        <CheckBox android:id="@+id/cb_block_torrent"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="Interdire le torrent"
                android:textColor="#333333" android:paddingStart="8dp"/>
            <CheckBox android:id="@+id/cb_game_mode"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="Mode Jeu 🎮 (Seuls les jeux utilisent le VPN)"
                android:textColor="#333333" android:paddingStart="8dp"/>
        </LinearLayout>

        <!-- Message utilisateur -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="  Message/Notes pour les utilisateurs (Optionnel)"
            android:textColor="#888888" android:textSize="12sp"
            android:background="#FFFFFF" android:padding="12dp"
            android:layout_marginTop="4dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="#FFFFFF" android:orientation="horizontal"
            android:gravity="bottom" android:paddingStart="16dp" android:paddingEnd="8dp"
            android:paddingBottom="8dp">
            <EditText android:id="@+id/et_user_message"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:hint="Message (HTML supporté)"
                android:textColor="#000000" android:textColorHint="#AAAAAA"
                android:background="@null" android:minLines="2" android:gravity="top"/>
            <Button android:id="@+id/btn_emoji"
                android:layout_width="36dp" android:layout_height="36dp"
                android:text="😊" android:backgroundTint="#EEEEEE"
                android:textSize="16sp" android:padding="0dp"/>
        </LinearLayout>

    
    <!-- Tunnels à inclure -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="  Tunnels à inclure" android:textColor="#009688" android:textSize="13sp"
        android:background="#E0F2F1" android:padding="12dp" android:layout_marginTop="8dp"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="#FFFFFF" android:orientation="vertical" android:padding="8dp">
        <CheckBox android:id="@+id/cb_tunnel_slowdns" android:layout_width="match_parent"
            android:layout_height="48dp" android:text="SlowDNS"
            android:textColor="#333333" android:paddingStart="8dp" android:checked="true"/>
        <CheckBox android:id="@+id/cb_tunnel_http" android:layout_width="match_parent"
            android:layout_height="48dp" android:text="HTTP Proxy + Payload"
            android:textColor="#333333" android:paddingStart="8dp" android:checked="true"/>
        <CheckBox android:id="@+id/cb_tunnel_ws" android:layout_width="match_parent"
            android:layout_height="48dp" android:text="SSH WebSocket"
            android:textColor="#333333" android:paddingStart="8dp" android:checked="true"/>
        <CheckBox android:id="@+id/cb_tunnel_ssl" android:layout_width="match_parent"
            android:layout_height="48dp" android:text="SSH SSL/TLS"
            android:textColor="#333333" android:paddingStart="8dp" android:checked="true"/>
        <CheckBox android:id="@+id/cb_tunnel_xray" android:layout_width="match_parent"
            android:layout_height="48dp" android:text="V2Ray / Xray"
            android:textColor="#333333" android:paddingStart="8dp" android:checked="true"/>
        <CheckBox android:id="@+id/cb_tunnel_v2dns" android:layout_width="match_parent"
            android:layout_height="48dp" android:text="V2Ray + SlowDNS"
            android:textColor="#333333" android:paddingStart="8dp" android:checked="true"/>
        <CheckBox android:id="@+id/cb_tunnel_hysteria" android:layout_width="match_parent"
            android:layout_height="48dp" android:text="Hysteria UDP"
            android:textColor="#333333" android:paddingStart="8dp" android:checked="true"/>
    </LinearLayout>

    <!-- Cloud Config -->
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="  Export Cloud" android:textColor="#009688" android:textSize="13sp"
        android:background="#E0F2F1" android:padding="12dp" android:layout_marginTop="8dp"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="#FFFFFF" android:orientation="vertical" android:padding="16dp">
        <RadioGroup android:id="@+id/rg_cloud_type" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:orientation="vertical">
            <RadioButton android:id="@+id/rb_cloud_normal" android:layout_width="match_parent"
                android:layout_height="48dp" android:text="Config normale (pas d'expiration)"
                android:textColor="#333333" android:checked="true"/>
            <RadioButton android:id="@+id/rb_cloud_limited" android:layout_width="match_parent"
                android:layout_height="48dp" android:text="Config limitée (durée en minutes)"
                android:textColor="#333333"/>
        </RadioGroup>
        <LinearLayout android:id="@+id/layout_cloud_duration"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:visibility="gone" android:layout_marginTop="8dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Durée (minutes): " android:textColor="#333333"/>
            <EditText android:id="@+id/et_cloud_duration"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:hint="Ex: 60"
                android:inputType="number" android:textColor="#000000"
                android:textColorHint="#AAAAAA" android:background="@null" android:padding="8dp"/>
        </LinearLayout>
        <Button android:id="@+id/btn_export_cloud"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="☁️ Exporter vers le cloud" android:backgroundTint="#00796B"
            android:textColor="#FFFFFF" android:textSize="13sp" android:layout_marginTop="8dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginTop="8dp" android:visibility="gone"
            android:id="@+id/layout_cloud_result">
            <TextView android:id="@+id/tv_cloud_code"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textColor="#009688" android:textSize="16sp"
                android:textStyle="bold"/>
            <Button android:id="@+id/btn_copy_cloud_code"
                android:layout_width="36dp" android:layout_height="36dp"
                android:text="📋" android:backgroundTint="#EEEEEE" android:textSize="14sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Boutons Export -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp"
            android:layout_marginTop="8dp">
            <Button android:id="@+id/btn_export_save_file"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="💾  ENREGISTRER FICHIER" android:backgroundTint="#009688"
                android:textColor="#FFFFFF" android:textSize="14sp" android:layout_marginBottom="8dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
