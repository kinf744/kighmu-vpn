<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1117">

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">
        <LinearLayout
            android:id="@+id/tab_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp">

            <Button android:id="@+id/tab_slowdns"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="SlowDNS" android:textSize="11sp"
                android:backgroundTint="#2196F3" android:textColor="#FFFFFF"
                android:layout_margin="2dp" android:paddingStart="10dp" android:paddingEnd="10dp"/>
            <Button android:id="@+id/tab_http"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="HTTP Proxy" android:textSize="11sp"
                android:backgroundTint="#333344" android:textColor="#FFFFFF"
                android:layout_margin="2dp" android:paddingStart="10dp" android:paddingEnd="10dp"/>
            <Button android:id="@+id/tab_ws"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="SSH WS" android:textSize="11sp"
                android:backgroundTint="#333344" android:textColor="#FFFFFF"
                android:layout_margin="2dp" android:paddingStart="10dp" android:paddingEnd="10dp"/>
            <Button android:id="@+id/tab_ssl"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="SSH SSL" android:textSize="11sp"
                android:backgroundTint="#333344" android:textColor="#FFFFFF"
                android:layout_margin="2dp" android:paddingStart="10dp" android:paddingEnd="10dp"/>
            <Button android:id="@+id/tab_xray"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="V2Ray/Xray" android:textSize="11sp"
                android:backgroundTint="#333344" android:textColor="#FFFFFF"
                android:layout_margin="2dp" android:paddingStart="10dp" android:paddingEnd="10dp"/>
            <Button android:id="@+id/tab_v2dns"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="V2Ray+DNS" android:textSize="11sp"
                android:backgroundTint="#333344" android:textColor="#FFFFFF"
                android:layout_margin="2dp" android:paddingStart="10dp" android:paddingEnd="10dp"/>
            <Button android:id="@+id/tab_hysteria"
                android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="Hysteria" android:textSize="11sp"
                android:backgroundTint="#333344" android:textColor="#FFFFFF"
                android:layout_margin="2dp" android:paddingStart="10dp" android:paddingEnd="10dp"/>
        </LinearLayout>
    </HorizontalScrollView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/config_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- SSH Common Fields -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="SSH Server" android:textColor="#4FC3F7" android:textSize="13sp"
                android:textAllCaps="true" android:layout_marginBottom="8dp"/>
            <EditText android:id="@+id/et_ssh_host" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:hint="Host / IP"
                android:textColor="#FFFFFF" android:textColorHint="#666666"
                android:backgroundTint="#333344" android:padding="10dp"/>
            <EditText android:id="@+id/et_ssh_port" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:hint="Port (22)"
                android:inputType="number" android:textColor="#FFFFFF" android:textColorHint="#666666"
                android:backgroundTint="#333344" android:padding="10dp" android:layout_marginTop="8dp"/>
            <EditText android:id="@+id/et_ssh_user" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:hint="Username"
                android:textColor="#FFFFFF" android:textColorHint="#666666"
                android:backgroundTint="#333344" android:padding="10dp" android:layout_marginTop="8dp"/>
            <EditText android:id="@+id/et_ssh_pass" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:hint="Password"
                android:inputType="textPassword" android:textColor="#FFFFFF" android:textColorHint="#666666"
                android:backgroundTint="#333344" android:padding="10dp" android:layout_marginTop="8dp"/>

            <!-- SlowDNS Panel -->
            <LinearLayout android:id="@+id/panel_slowdns"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginTop="16dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="SlowDNS Settings" android:textColor="#4FC3F7" android:textSize="13sp"
                    android:textAllCaps="true" android:layout_marginBottom="8dp"/>
                <EditText android:id="@+id/et_dns_server" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="DNS Server (8.8.8.8)"
                    android:textColor="#FFFFFF" android:textColorHint="#666666"
                    android:backgroundTint="#333344" android:padding="10dp"/>
                <EditText android:id="@+id/et_dns_nameserver" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="Nameserver"
                    android:textColor="#FFFFFF" android:textColorHint="#666666"
                    android:backgroundTint="#333344" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/et_dns_pubkey" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="Public Key"
                    android:textColor="#FFFFFF" android:textColorHint="#666666"
                    android:backgroundTint="#333344" android:padding="10dp" android:layout_marginTop="8dp"/>
            </LinearLayout>

            <!-- HTTP Proxy Panel -->
            <LinearLayout android:id="@+id/panel_http"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginTop="16dp"
                android:visibility="gone">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="HTTP Proxy Settings" android:textColor="#4FC3F7" android:textSize="13sp"
                    android:textAllCaps="true" android:layout_marginBottom="8dp"/>
                <EditText android:id="@+id/et_proxy_host" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="Proxy Host"
                    android:textColor="#FFFFFF" android:textColorHint="#666666"
                    android:backgroundTint="#333344" android:padding="10dp"/>
                <EditText android:id="@+id/et_proxy_port" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="Proxy Port (8080)"
                    android:inputType="number" android:textColor="#FFFFFF" android:textColorHint="#666666"
                    android:backgroundTint="#333344" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/et_payload" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="Custom Payload"
                    android:textColor="#FFFFFF" android:textColorHint="#666666"
                    android:backgroundTint="#333344" android:padding="10dp" android:layout_marginTop="8dp"
                    android:minLines="3" android:gravity="top"/>
            </LinearLayout>

            <!-- WebSocket Panel -->
            <LinearLayout android:id="@+id/panel_ws"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginTop="16dp"
                android:visibility="gone">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="WebSocket Settings" android:textColor="#4FC3F7" android:textSize="13sp"
                    android:textAllCaps="true" android:layout_marginBottom="8dp"/>
                <EditText android:id="@+id/et_ws_host" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="WS Host"
                    android:textColor="#FFFFFF" android:textColorHint="#666666"
                    android:backgroundTint="#333344" android:padding="10dp"/>
                <EditText android:id="@+id/et_ws_port" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="WS Port (80)"
                    android:inputType="number" android:textColor="#FFFFFF" android:textColorHint="#666666"
                    android:backgroundTint="#333344" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/et_ws_path" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="Path (/)"
                    android:textColor="#FFFFFF" android:textColorHint="#666666"
                    android:backgroundTint="#333344" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/et_ws_payload" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="Custom Payload"
                    android:textColor="#FFFFFF" android:textColorHint="#666666"
                    android:backgroundTint="#333344" android:padding="10dp" android:layout_marginTop="8dp"
                    android:minLines="3" android:gravity="top"/>
            </LinearLayout>

            <!-- SSL Panel -->
            <LinearLayout android:id="@+id/panel_ssl"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginTop="16dp"
                android:visibility="gone">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="SSL/TLS Settings" android:textColor="#4FC3F7" android:textSize="13sp"
                    android:textAllCaps="true" android:layout_marginBottom="8dp"/>
                <EditText android:id="@+id/et_ssl_host" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="SSL Host"
                    android:textColor="#FFFFFF" android:textColorHint="#666666"
                    android:backgroundTint="#333344" android:padding="10dp"/>
                <EditText android:id="@+id/et_ssl_port" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="SSL Port (443)"
                    android:inputType="number" android:textColor="#FFFFFF" android:textColorHint="#666666"
                    android:backgroundTint="#333344" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/et_sni" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="SNI"
                    android:textColor="#FFFFFF" android:textColorHint="#666666"
                    android:backgroundTint="#333344" android:padding="10dp" android:layout_marginTop="8dp"/>
            </LinearLayout>

            <!-- Xray Panel -->
            <LinearLayout android:id="@+id/panel_xray"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginTop="16dp"
                android:visibility="gone">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="V2Ray/Xray Settings" android:textColor="#4FC3F7" android:textSize="13sp"
                    android:textAllCaps="true" android:layout_marginBottom="8dp"/>
                <EditText android:id="@+id/et_xray_host" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="Server Address"
                    android:textColor="#FFFFFF" android:textColorHint="#666666"
                    android:backgroundTint="#333344" android:padding="10dp"/>
                <EditText android:id="@+id/et_xray_port" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="Port (443)"
                    android:inputType="number" android:textColor="#FFFFFF" android:textColorHint="#666666"
                    android:backgroundTint="#333344" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/et_xray_uuid" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="UUID"
                    android:textColor="#FFFFFF" android:textColorHint="#666666"
                    android:backgroundTint="#333344" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/et_xray_path" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="WS Path (/)"
                    android:textColor="#FFFFFF" android:textColorHint="#666666"
                    android:backgroundTint="#333344" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/et_xray_sni" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="SNI"
                    android:textColor="#FFFFFF" android:textColorHint="#666666"
                    android:backgroundTint="#333344" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/et_xray_json" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="Or paste full JSON config"
                    android:textColor="#FFFFFF" android:textColorHint="#666666"
                    android:backgroundTint="#333344" android:padding="10dp" android:layout_marginTop="8dp"
                    android:minLines="5" android:gravity="top"/>
            </LinearLayout>

            <!-- Hysteria Panel -->
            <LinearLayout android:id="@+id/panel_hysteria"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginTop="16dp"
                android:visibility="gone">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Hysteria UDP Settings" android:textColor="#4FC3F7" android:textSize="13sp"
                    android:textAllCaps="true" android:layout_marginBottom="8dp"/>
                <EditText android:id="@+id/et_hys_host" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="Server Host"
                    android:textColor="#FFFFFF" android:textColorHint="#666666"
                    android:backgroundTint="#333344" android:padding="10dp"/>
                <EditText android:id="@+id/et_hys_port" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="Port (443)"
                    android:inputType="number" android:textColor="#FFFFFF" android:textColorHint="#666666"
                    android:backgroundTint="#333344" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/et_hys_auth" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="Auth String"
                    android:textColor="#FFFFFF" android:textColorHint="#666666"
                    android:backgroundTint="#333344" android:padding="10dp" android:layout_marginTop="8dp"/>
                <EditText android:id="@+id/et_hys_sni" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="SNI"
                    android:textColor="#FFFFFF" android:textColorHint="#666666"
                    android:backgroundTint="#333344" android:padding="10dp" android:layout_marginTop="8dp"/>
            </LinearLayout>

            <Button android:id="@+id/btn_save_config"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="SAVE CONFIG" android:backgroundTint="#2196F3"
                android:textColor="#FFFFFF" android:layout_marginTop="24dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>