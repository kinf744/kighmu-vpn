<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="PARAMÈTRES" android:textColor="#4FC3F7"
            android:textSize="16sp" android:textAllCaps="true" android:layout_marginBottom="16dp"/>

        <!-- Hardware ID -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="HARDWARE ID" android:textColor="#4FC3F7"
            android:textSize="13sp" android:textAllCaps="true"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="8dp">
            <TextView android:id="@+id/tv_hardware_id"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="..."
                android:textColor="#00E5FF" android:textSize="12sp"
                android:fontFamily="monospace" android:padding="12dp"
                android:background="#1A1F2E"/>
            <Button android:id="@+id/btn_copy_hwid"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="COPIER" android:backgroundTint="#1565C0"
                android:textColor="#FFFFFF" android:textSize="11sp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        

        <!-- Notifications -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="COMPORTEMENT" android:textColor="#4FC3F7"
            android:textSize="13sp" android:textAllCaps="true" android:layout_marginTop="16dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
            <Switch android:id="@+id/switch_notifications"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Notifications VPN actif"
                android:textColor="#FFFFFF" android:textSize="13sp" android:layout_marginStart="8dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
            <Switch android:id="@+id/switch_auto_reconnect"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Auto reconnect"
                android:textColor="#FFFFFF" android:textSize="13sp" android:layout_marginStart="8dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
            <Switch android:id="@+id/switch_kill_switch"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Kill Switch (bloque Internet si VPN tombe)"
                android:textColor="#FFFFFF" android:textSize="13sp" android:layout_marginStart="8dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
            <Switch android:id="@+id/switch_dns_protection"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Protection fuite DNS"
                android:textColor="#FFFFFF" android:textSize="13sp" android:layout_marginStart="8dp"/>
        </LinearLayout>

        
        <!-- Langue -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="LANGUE" android:textColor="#4FC3F7"
            android:textSize="13sp" android:textAllCaps="true" android:layout_marginTop="16dp"/>
        <Spinner android:id="@+id/spinner_language"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:layout_marginTop="8dp" android:background="#1A1F2E"/>

        <!-- Thème -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="THÈME" android:textColor="#4FC3F7"
            android:textSize="13sp" android:textAllCaps="true" android:layout_marginTop="16dp"/>
        <Spinner android:id="@+id/spinner_theme"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:layout_marginTop="8dp" android:background="#1A1F2E"/>

        <!-- Options supplémentaires -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="RÉSEAU ET SYSTÈME" android:textColor="#4FC3F7"
            android:textSize="13sp" android:textAllCaps="true" android:layout_marginTop="16dp"/>
            
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
            <Switch android:id="@+id/switch_wakelock"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Wakelock (Empêcher la mise en veille)"
                android:textColor="#FFFFFF" android:textSize="13sp" android:layout_marginStart="8dp"/>
        </LinearLayout>
        
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
            <Switch android:id="@+id/switch_http_ping"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="HTTP Ping"
                android:textColor="#FFFFFF" android:textSize="13sp" android:layout_marginStart="8dp"/>
        </LinearLayout>
        
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
            <Switch android:id="@+id/switch_keepalive"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Keepalive"
                android:textColor="#FFFFFF" android:textSize="13sp" android:layout_marginStart="8dp"/>
        </LinearLayout>
        
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
            <Switch android:id="@+id/switch_compression"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Compression"
                android:textColor="#FFFFFF" android:textSize="13sp" android:layout_marginStart="8dp"/>
        </LinearLayout>
        
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
            <Switch android:id="@+id/switch_enable_dns"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Enable DNS"
                android:textColor="#FFFFFF" android:textSize="13sp" android:layout_marginStart="8dp"/>
        </LinearLayout>
        
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
            <Switch android:id="@+id/switch_dns_forwarding"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="DNS Forwarding"
                android:textColor="#FFFFFF" android:textSize="13sp" android:layout_marginStart="8dp"/>
        </LinearLayout>
        
        <!-- DNS -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="DNS PRIMAIRE" android:textColor="#888888" android:textSize="12sp" android:layout_marginTop="8dp"/>
        <EditText android:id="@+id/et_dns_primary"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="8.8.8.8" android:textColor="#FFFFFF" android:textColorHint="#555555"
            android:background="#1A1F2E" android:padding="12dp" android:layout_marginTop="4dp"/>
            
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="DNS SECONDAIRE" android:textColor="#888888" android:textSize="12sp" android:layout_marginTop="8dp"/>
        <EditText android:id="@+id/et_dns_secondary"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="8.8.4.4" android:textColor="#FFFFFF" android:textColorHint="#555555"
            android:background="#1A1F2E" android:padding="12dp" android:layout_marginTop="4dp"/>
            
        <!-- MTU et UDPGW -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="16dp" android:baselineAligned="false">
            
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="MTU" android:textColor="#888888" android:textSize="12sp"/>
                <EditText android:id="@+id/et_mtu"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="1500" android:inputType="number" android:textColor="#FFFFFF" 
                    android:textColorHint="#555555" android:background="#1A1F2E" android:padding="12dp" 
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
            
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="UDPGW" android:textColor="#888888" android:textSize="12sp"/>
                <EditText android:id="@+id/et_udpgw"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="7300" android:inputType="number" android:textColor="#FFFFFF" 
                    android:textColorHint="#555555" android:background="#1A1F2E" android:padding="12dp" 
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Version -->
        <TextView android:id="@+id/tv_app_version"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Version 1.0.0" android:textColor="#666666"
            android:textSize="12sp" android:layout_marginTop="24dp" android:gravity="center"/>

    </LinearLayout>
</ScrollView>