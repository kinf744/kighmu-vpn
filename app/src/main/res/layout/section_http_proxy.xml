<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/surface_card"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HTTP PROXY + PAYLOAD"
                android:textSize="11sp"
                android:textColor="@color/accent_blue"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:boxStrokeColor="@color/accent_blue"
                app:hintTextColor="@color/text_hint"
                android:hint="@string/proxy_host">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_proxy_host"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:inputType="textUri" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:boxStrokeColor="@color/accent_blue"
                app:hintTextColor="@color/text_hint"
                android:hint="@string/proxy_port">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_proxy_port"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:inputType="number"
                    android:text="8080" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Payload Editor -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HTTP Payload"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Placeholders: [host] [port] [crlf] [cr] [lf]"
                android:textSize="11sp"
                android:textColor="@color/accent_blue"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:boxStrokeColor="@color/accent_blue"
                app:hintTextColor="@color/text_hint"
                android:hint="@string/custom_payload">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_payload"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:minLines="5"
                    android:maxLines="15"
                    android:gravity="top|start"
                    android:inputType="textMultiLine|textNoSuggestions"
                    android:text="GET / HTTP/1.1[crlf]Host: [host][crlf]Connection: Keep-Alive[crlf]Upgrade: websocket[crlf][crlf]" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:boxStrokeColor="@color/accent_blue"
                app:hintTextColor="@color/text_hint"
                android:hint="Custom Headers (Key: Value, one per line)">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_custom_headers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:minLines="3"
                    android:gravity="top|start"
                    android:inputType="textMultiLine|textNoSuggestions" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
